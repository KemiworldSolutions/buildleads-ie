# Get a key from https://platform.deepseek.com/api_keys
# €10 of credit is more than a month of runway at full Dublin volume.
DEEPSEEK_API_KEY=sk-replace-me

# SMTP (Fastmail, MXroute, or similar — NOT Gmail)
SMTP_HOST=smtp.fastmail.com
SMTP_PORT=465
SMTP_USER=you@yourdomain.ie
SMTP_PASS=app_password_here
FROM_NAME=Your Name
FROM_ADDRESS=you@yourdomain.ie

# IMAP (for response tracking — usually same provider as SMTP)
IMAP_HOST=imap.fastmail.com
IMAP_PORT=993
IMAP_USER=you@yourdomain.ie
IMAP_PASS=app_password_here

# Stripe (only needed once you set up the webhook)
STRIPE_API_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Optional: where to write outputs (defaults to ./out)
OUT_DIR=./out
